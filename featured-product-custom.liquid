<div class="featured-product" style="
  --fp-bg: {{ section.settings.background_color }};
  --fp-accent: {{ section.settings.accent_color }};
">
  <div class="featured-product__inner">

    <div class="featured-product__image-wrap">
      {%- if section.settings.product != blank -%}
        {%- assign product = section.settings.product -%}
        <img
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | escape }}"
          width="800"
          height="800"
          loading="lazy"
        >
      {%- elsif section.settings.custom_image != blank -%}
        <img
          src="{{ section.settings.custom_image | image_url: width: 800 }}"
          alt="{{ section.settings.heading }}"
          width="800"
          height="800"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}

      {%- if section.settings.badge != blank -%}
        <span class="featured-product__badge">{{ section.settings.badge }}</span>
      {%- endif -%}
    </div>

    <div class="featured-product__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="featured-product__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="featured-product__heading">
        {%- if section.settings.product != blank -%}
          {{ product.title }}
        {%- else -%}
          {{ section.settings.heading }}
        {%- endif -%}
      </h2>

      <p class="featured-product__description">
        {%- if section.settings.product != blank -%}
          {{ product.description | strip_html | truncate: 200 }}
        {%- else -%}
          {{ section.settings.description }}
        {%- endif -%}
      </p>

      {%- if section.settings.product != blank -%}
        <p class="featured-product__price">
          {{ product.price | money }}
        </p>
        <a href="{{ product.url }}" class="featured-product__btn">
          {{ section.settings.button_label | default: 'Ver produto' }}
        </a>
      {%- else -%}
        <p class="featured-product__price">{{ section.settings.price }}</p>
        <a href="{{ section.settings.button_url }}" class="featured-product__btn">
          {{ section.settings.button_label | default: 'Ver produto' }}
        </a>
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  .featured-product {
    background: var(--fp-bg, #f9f9f7);
    padding: 5rem 2rem;
  }

  .featured-product__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .featured-product__image-wrap {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .featured-product__image-wrap img,
  .featured-product__image-wrap .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-product__badge {
    position: absolute;
    top: 1.25rem;
    left: 1.25rem;
    background: var(--fp-accent, #1a1a1a);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 2px;
  }

  .featured-product__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fp-accent, #1a1a1a);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .featured-product__heading {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: #1a1a1a;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .featured-product__description {
    font-size: 1rem;
    line-height: 1.75;
    color: #2a1a14;
    margin-bottom: 1.5rem;
  }

  .featured-product__price {
    font-size: 1.4rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 2rem;
  }

  .featured-product__btn {
    display: inline-block;
    padding: 0.85rem 2rem;
    background: var(--fp-accent, #1a1a1a);
    color: #fff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 2px;
    transition: opacity 0.2s;
  }

  .featured-product__btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .featured-product__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Product",
  "tag": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produto"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Imagem (se não usar produto)"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "placeholder": "Novo, Exclusivo, -20%..."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto acima do título",
      "default": "Destaque da semana"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título (sem produto)",
      "default": "Nome do produto"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descrição (sem produto)",
      "default": "Descrição do produto aqui."
    },
    {
      "type": "text",
      "id": "price",
      "label": "Preço (sem produto)",
      "default": "R$ 299,00"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão",
      "default": "Ver produto"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link do botão"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#f9f9f7"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor de destaque",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}
